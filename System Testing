## 5. Writing Test Code

The test file is located at `marketplace/tests.py`. All eight test cases are implemented in a single class, `ItemListingTests`, which sends real HTTP requests through Django's test `Client` to the `item_create` view. This approach tests the full stack — form validation, view logic, and database state — in one pass.

A class-level `@override_settings` decorator replaces `CompressedManifestStaticFilesStorage` with plain `StaticFilesStorage` so that template rendering succeeds without a pre-built static-file manifest.

```python
"""
marketplace/tests.py
====================
Tests for the item-listing / uploading component.

  TC01 — valid listing is posted and saved
  TC02 — missing title is rejected
  TC03 — missing description is rejected
  TC04 — missing price is rejected
  TC05 — negative price is rejected
  TC06 — missing category is rejected
  TC07 — multiple fields missing
  TC08 — all fields empty
"""

from django.test import TestCase, Client, override_settings
from django.urls import reverse
from django.contrib.auth import get_user_model

from marketplace.models import Category, Item

User = get_user_model()

_STATIC_OVERRIDE = override_settings(
    STATICFILES_STORAGE='django.contrib.staticfiles.storage.StaticFilesStorage'
)


def make_user(email, full_name='Test User', password='TestPass123!'):
    return User.objects.create_user(
        email=email, password=password, full_name=full_name,
    )


@_STATIC_OVERRIDE
class ItemListingTests(TestCase):

    def setUp(self):
        self.client   = Client()
        self.seller   = make_user('seller@example.com', 'Seller')
        self.category = Category.objects.create(name='Electronics')
        self.url      = reverse('marketplace:item_create')
        self.client.login(username='seller@example.com', password='TestPass123!')

    def _valid_post(self, **overrides):
        data = {
            'itemName':    'Vintage Lamp',
            'itemPrice':   '20.00',
            'categoryID':  self.category.pk,
            'condition':   'good',
            'description': 'A beautiful vintage lamp.',
            'city':        'Tirane',
        }
        data.update(overrides)
        return data

    def test_tc01_valid_listing_is_posted(self):
        """TC01: All fields valid — item is saved and view redirects."""
        response = self.client.post(self.url, data=self._valid_post())
        self.assertEqual(response.status_code, 302)
        self.assertTrue(Item.objects.filter(itemName='Vintage Lamp').exists())

    def test_tc02_missing_title_is_rejected(self):
        """TC02: Empty title — form must re-render with an error on itemName."""
        response = self.client.post(self.url, data=self._valid_post(itemName=''))
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc03_missing_description_is_rejected(self):
        """TC03: Empty description — form must re-render with an error on description."""
        response = self.client.post(self.url, data=self._valid_post(description=''))
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc04_missing_price_is_rejected(self):
        """TC04: Empty price — form must re-render with an error on itemPrice."""
        response = self.client.post(self.url, data=self._valid_post(itemPrice=''))
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc05_negative_price_is_rejected(self):
        """TC05: Negative price — form must re-render with an error on itemPrice."""
        response = self.client.post(self.url, data=self._valid_post(itemPrice='-10'))
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc06_missing_category_is_rejected(self):
        """TC06: No category selected — form must re-render with an error on categoryID."""
        data = self._valid_post()
        data.pop('categoryID')
        response = self.client.post(self.url, data=data)
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc07_multiple_fields_missing_is_rejected(self):
        """TC07: Both title and price empty — form must re-render."""
        response = self.client.post(
            self.url, data=self._valid_post(itemName='', itemPrice=''))
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())

    def test_tc08_all_fields_empty_is_rejected(self):
        """TC08: Completely empty POST — form must re-render, no item saved."""
        response = self.client.post(self.url, data={})
        self.assertEqual(response.status_code, 200)
        self.assertFalse(Item.objects.exists())
```

