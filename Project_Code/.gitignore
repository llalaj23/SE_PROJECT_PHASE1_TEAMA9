# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ─── Virtual Environment ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── Django ───────────────────────────────────────────────────────────────────
*.log
db.sqlite3          # We use PostgreSQL, but block SQLite just in case
media/              # User-uploaded images — never commit to git
staticfiles/        # Generated by collectstatic — never commit

# ─── Environment Secrets ──────────────────────────────────────────────────────
# CRITICAL: .env contains passwords and secret keys. Never commit it.
.env

# ─── OS & Editor Junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
