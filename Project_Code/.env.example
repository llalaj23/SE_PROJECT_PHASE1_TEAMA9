SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/again_and_again

# ─── Email ────────────────────────────────────────────────────────────────────
# To send real emails (recommended):
#   1. Create a Gmail account for the app e.g. againandagain.noreply@gmail.com
#   2. Enable 2FA on that account
#   3. Go to: Google Account → Security → 2-Step Verification → App Passwords
#   4. Create an App Password named "Django" — copy the 16-character code
#   5. Fill in EMAIL_HOST_USER and EMAIL_HOST_PASSWORD below
#   6. Change EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend
#
# To print emails to the terminal instead (no Gmail needed, for quick testing):
#   Leave EMAIL_BACKEND as django.core.mail.backends.console.EmailBackend

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-app-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# ─── Email Verification ───────────────────────────────────────────────────────
# 'mandatory' = users must verify email before logging in (recommended)
# 'optional'  = verification email sent but not required
# 'none'      = no verification at all (use only for development)
ACCOUNT_EMAIL_VERIFICATION=mandatory

FIELD_ENCRYPTION_KEY=your-32-byte-encryption-key-here
